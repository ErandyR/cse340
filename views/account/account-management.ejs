<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
    <% } else { res.redirect('/') } %>

        <%- messages() %>

            <% if (errors) { %>
                <ul class="notice">
                    <% errors.array().forEach(error=> { %>
                        <li>
                            <%= error.msg %>
                        </li>
                        <% }) %>
                </ul>
                <% } %>

                    <h2>Welcome <%= account_firstname %>
                            <%= account_lastname %>
                    </h2>

                    <!-- LINK UPDATE ACCOUNT SIEMPRE VISIBLE -->
                    <p>
                        <a href="/account/update/<%= account_id %>">
                            Update Account Information
                        </a>
                    </p>

                    <p>
                        <a href="/account/garage">View My Garage</a>
                    </p>

                    <!-- SOLO EMPLOYEE / ADMIN -->
                    <% if (account_type==="Employee" || account_type==="Admin" ) { %>

                        <h3>Inventory Management</h3>

                        <p>
                            <a href="/inv/">
                                Go to Inventory Management
                            </a>
                        </p>

                        <% } %>